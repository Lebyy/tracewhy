{
  "name": "tracewhy",
  "version": "1.0.1",
  "description": "Deterministic, evidence-linked Linux command debugging",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lebyy/tracewhy.git"
  },
  "bugs": "https://github.com/Lebyy/tracewhy/issues",
