{
  "name": "tracewhy",
  "version": "1.0.0",
  "private": true,
  "description": "Deterministic, evidence-linked environment debugging",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lebyy/tracewhy.git"
  },
  "bugs": "https://github.com/Lebyy/tracewhy/issues",
  "homepage": "https://github.com/Lebyy/tracewhy#readme",
  "keywords": ["debugging", "strace", "linux", "cli", "deterministic"],
  "packageManager": "bun@1.3.14",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "build": "bun run build:core && bun run build:cli && bun run build:web",
    "build:core": "cargo build --locked --release -p trace-core && bun scripts/stage-core.ts",
    "build:cli": "bun scripts/build-cli.ts",
    "build:web": "bun run --cwd apps/web build && bun scripts/stage-web.ts",
    "build:showcase": "bun scripts/build-showcase-suite.ts",
    "verify:portable": "bun scripts/verify-portable.ts",
    "check": "bun run check:versions && bun run check:format && bun run check:core && bun run check:shell && bun run check:ts",
    "check:versions": "bun scripts/check-versions.ts",
    "check:format": "cargo fmt --all -- --check",
    "check:core": "cargo clippy --locked --workspace --all-targets -- -D warnings",
    "check:shell": "shellcheck scripts/*.sh demos/*.sh demos/*/*.sh",
    "check:ts": "bun run tsc --noEmit",
    "test": "bun run test:core && bun run test:cli",
    "test:core": "cargo test --locked --workspace",
    "test:cli": "bun test apps/cli apps/web packages/schema",
    "audit:js": "bun audit --audit-level=high",
    "dev:web": "bun run --cwd apps/web dev"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "typescript": "7.0.2"
  },
  "overrides": {
    "postcss": "8.5.14"
  },
  "engines": {
    "bun": ">=1.3.14"
  }
}
